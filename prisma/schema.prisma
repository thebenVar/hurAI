// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  createdAt   DateTime     @default(now())
  departments Department[]
  users       User[]
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String
  image          String?
  passwordHash   String?
  role           String           @default("guest")
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  departments    UserDepartment[]
  tickets        Ticket[]         @relation("TicketCreator")
  assignedTickets Ticket[]        @relation("TicketAssignee")
  activities     ActivityLog[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Department {
  id             String           @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  users          UserDepartment[]
  tickets        Ticket[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model UserDepartment {
  id           String     @id @default(cuid())
  userId       String
  departmentId String
  role         String     @default("member")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
}

model Ticket {
  id              String   @id @default(cuid())
  contact         String
  source          String // "phone" | "email" | "whatsapp" | "in-person" | "other"
  duration        String
  topic           String
  sentiment       String // "positive" | "neutral" | "negative"
  priority        String // "low" | "medium" | "high"
  summary         String
  keyIssues       String // Stored as JSON string
  potentialCauses String // Stored as JSON string
  
  // AI Attributes
  subCategory        String?
  isUserSolvable     Boolean?
  userSolvableReason String?
  followUpQuestions  String? // Stored as JSON string
  aiSummary          String? // LLM-generated executive summary

  // Legacy field
  assignee  String?
  
  // New Relational DB fields
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  creatorId      String?
  creator        User?        @relation("TicketCreator", fields: [creatorId], references: [id])
  assigneeId     String?
  assignedTo     User?        @relation("TicketAssignee", fields: [assigneeId], references: [id])

  // Interactive/PR-like features
  isEscalated       Boolean  @default(false)
  escalationReason  String?
  satisfactionScore Int?     // e.g., 1-5 rating

  status    String // "open" | "in-progress" | "resolved" | "closed" | "deleted"
  category  String // "hardware" | "software" | "network" | "access" | "translation" | "training" | "logistics" | "other"
  timeSpent String
  
  ticketNumber Int?     @unique // Sequential human-readable ID
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actionPoints ActionPoint[]
  activityLog  ActivityLog[]
}

model ActionPoint {
  id           String  @id @default(cuid())
  text         String
  completed    Boolean @default(false)
  isNextAction Boolean @default(false)
  
  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String   // "status_change" | "comment" | "note" | "log" | "file" | "message" | "call"
  author    String   // Legacy field
  userId    String?  // New relational DB field
  user      User?    @relation(fields: [userId], references: [id])
  
  timestamp DateTime @default(now())
  content   String
  metadata  String?  // JSON string
  
  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id                    String   @id @default("default_settings")
  defaultModel          String   @default("GPT-4o")
  encryptedOpenAiKey    String?
  encryptedAnthropicKey String?
  encryptedGeminiKey    String?
  updatedAt             DateTime @updatedAt
}
